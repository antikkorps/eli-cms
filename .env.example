# Database
DATABASE_URL=postgresql://eli:eli_secret@localhost:5432/eli_cms

# Auth
JWT_SECRET=change-me-to-a-random-secret-min-32
JWT_REFRESH_SECRET=change-me-to-another-random-secret-32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
API_KEY_SALT=change-me-api-key-salt-min-16

# API
API_PORT=8080
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
FRONTEND_URL=http://localhost:3000

# SMTP (optional — for password reset emails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_AUTH_TYPE=password
# SMTP_USER=user@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM_NAME=Eli CMS
# SMTP_FROM_ADDRESS=noreply@example.com

# pgAdmin
PGADMIN_EMAIL=admin@eli-cms.com
PGADMIN_PASSWORD=admin
